# ── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost;Database=SaasTemplate;...

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_BASE_URL=https://app.example.com
APP_FRONTEND_URL=https://www.example.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# ── Ops ───────────────────────────────────────────────────────────────────────
OPS_API_KEY=replace-with-a-random-ops-key

# ── Observability (optional) ──────────────────────────────────────────────────
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable OpenTelemetry export (traces/metrics/logs).
# With no endpoint, the app runs normally and exports nothing.
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc        # or http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=api-key=...  # vendor auth headers
# OTEL_SERVICE_NAME=SaasTemplate.Api
# LOG_JSON=true                           # force JSON console logs (default true in Production)
# SENTRY_DSN=                             # error-tracking toggle
