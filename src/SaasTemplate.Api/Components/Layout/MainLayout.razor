@inherits LayoutComponentBase
@using SaasTemplate.Api.Auth
@using System.IdentityModel.Tokens.Jwt
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.AspNetCore.Components.Web
@inject DashboardSession Session
@inject NavigationManager Nav
@inject ProtectedSessionStorage SessionStorage
@inject IHttpContextAccessor HttpContextAccessor

@if (_ready)
{
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="mobile-header">
        <div class="mobile-header-brand">
            <svg aria-hidden="true" width="18" height="24" viewBox="0 0 120 160" fill="none"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            SaasTemplate
        </div>
        <button class="hamburger-btn"
                aria-label="@(_sidebarOpen ? "Close navigation" : "Open navigation")"
                aria-expanded="@(_sidebarOpen ? "true" : "false")"
                aria-controls="sidebar-nav"
                @onclick="ToggleSidebar">
            <span class="hamburger-icon" aria-hidden="true">
                <span></span><span></span><span></span>
            </span>
        </button>
    </header>

    @if (_sidebarOpen)
    {
        <div class="sidebar-backdrop is-open" @onclick="CloseSidebar"></div>
    }

    <div class="layout">
        <nav id="sidebar-nav" class="sidebar @(_sidebarOpen ? "is-open" : "")" aria-label="Application navigation">
            <div class="sidebar-brand">
                <span class="sidebar-brand-name" style="display:flex;align-items:center;gap:0.5rem;">
                    <svg aria-hidden="true" width="18" height="24" viewBox="0 0 120 160" fill="none"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    SaasTemplate
                </span>
            </div>
            <ul class="nav-links">
                <li><a href="/" aria-current="@(IsActivePage("/") ? "page" : null)" class="@(IsActivePage("/") ? "nav-active" : "")" @onclick="CloseSidebar">Dashboard</a></li>
                <li><a href="/billing" aria-current="@(IsActivePage("/billing") ? "page" : null)" class="@(IsActivePage("/billing") ? "nav-active" : "")" @onclick="CloseSidebar">Billing</a></li>
                <li><a href="/settings" aria-current="@(IsActivePage("/settings") ? "page" : null)" class="@(IsActivePage("/settings") ? "nav-active" : "")" @onclick="CloseSidebar">Settings</a></li>
            </ul>
            @if (Session.IsAuthenticated)
            {
                <div class="sidebar-user">
                    <div class="sidebar-user-email">@Session.Email</div>
                    <button class="btn btn-secondary btn-sm" @onclick="Logout" style="width:100%;justify-content:center;">Sign out</button>
                    <a href="mailto:support@example.com" class="sidebar-support-link"
                       aria-label="Email support at support@example.com">
                        Need help? support@example.com
                    </a>
                </div>
            }
        </nav>

        <div class="top-bar">
            <nav aria-label="Breadcrumb" class="breadcrumb">
                <a href="/">Dashboard</a>
                @if (!string.IsNullOrEmpty(_currentPageName) && _currentPageName != "Dashboard")
                {
                    <span aria-hidden="true">/</span>
                    <span class="breadcrumb-current" aria-current="page">@_currentPageName</span>
                }
            </nav>

            @if (Session.IsAuthenticated)
            {
                <div style="position:relative;" class="@(_dropdownOpen ? "profile-dropdown-open" : "")">
                    <button class="profile-trigger"
                            aria-expanded="@(_dropdownOpen ? "true" : "false")"
                            aria-haspopup="true"
                            @onclick="ToggleDropdown"
                            @onclick:stopPropagation="true"
                            @onkeydown="OnDropdownKeyDown">
                        <span class="profile-avatar" aria-hidden="true">@(Session.Email?.Substring(0, 1).ToUpper())</span>
                        <span class="profile-email">@Session.Email</span>
                        <span class="profile-chevron" aria-hidden="true"></span>
                    </button>
                    @if (_dropdownOpen)
                    {
                        <div class="profile-menu" @onclick:stopPropagation="true">
                            <a href="/settings">Settings</a>
                            <a href="/billing">Billing</a>
                            <a href="mailto:support@example.com">Support</a>
                            <button @onclick="Logout">Sign out</button>
                        </div>
                    }
                </div>
            }
        </div>

        <main id="main-content" class="main-content" tabindex="-1">
            @Body
        </main>
    </div>
}
else
{
    <div class="loading" role="status" aria-live="polite">Loading&hellip;</div>
}

@code {
    private bool _ready;
    private bool _sidebarOpen;
    private bool _dropdownOpen;
    private string _currentPageName = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Rehydrate DashboardSession from ProtectedSessionStorage if the in-memory
        // session was lost (e.g., after Stripe checkout redirect breaks the circuit).
        if (!Session.IsAuthenticated)
        {
            try
            {
                var result = await SessionStorage.GetAsync<SessionData>("auth");
                if (result.Success && result.Value is not null)
                {
                    Session.SetUser(result.Value.Token, result.Value.UserId, result.Value.Email);
                }
            }
            catch
            {
                // No stored session or decryption failed — try cookie fallback below
            }
        }

        // Fallback: check for access_token cookie set by Google OAuth callback.
        // Blazor components can't reliably handle OAuth redirects, so the callback
        // sets a short-lived cookie that we consume here.
        if (!Session.IsAuthenticated)
        {
            var token = HttpContextAccessor.HttpContext?.Request.Cookies["access_token"];
            if (!string.IsNullOrEmpty(token))
            {
                try
                {
                    var handler = new JwtSecurityTokenHandler();
                    var jwt = handler.ReadJwtToken(token);
                    var userId = jwt.Subject;
                    var email = jwt.Claims.FirstOrDefault(c => c.Type == "email")?.Value ?? "";

                    if (!string.IsNullOrEmpty(userId))
                    {
                        Session.SetUser(token, userId, email);
                        // Persist to SessionStorage for future rehydration and delete the cookie
                        await SessionStorage.SetAsync("auth", new { Session.Token, UserId = Session.UserId!, Email = Session.Email! });
                        HttpContextAccessor.HttpContext?.Response.Cookies.Delete("access_token");
                    }
                }
                catch
                {
                    // Invalid JWT in cookie — ignore
                }
            }
        }

        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        _ready = true;
        _currentPageName = GetPageName();
        StateHasChanged();
    }

    private async Task Logout()
    {
        await SessionStorage.DeleteAsync("auth");
        Session.Clear();
        Nav.NavigateTo("/login");
    }

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() { _sidebarOpen = false; _dropdownOpen = false; }
    private void ToggleDropdown() => _dropdownOpen = !_dropdownOpen;

    private async Task OnDropdownKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _dropdownOpen = false;
        }
    }

    private string GetPageName()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        return path switch
        {
            "" => "Dashboard",
            "billing" => "Billing",
            "settings" => "Settings",
            _ => ""
        };
    }

    private bool IsActivePage(string href)
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        if (href == "/") return string.IsNullOrEmpty(relativePath);
        return ("/" + relativePath).StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    private sealed record SessionData(string Token, string UserId, string Email);
}
