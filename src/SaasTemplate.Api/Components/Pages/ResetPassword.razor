@page "/auth/reset-password"
@layout EmptyLayout
@using System.Net.Http.Json
@using System.Text.Json
@using SaasTemplate.Api.Auth
@inject IHttpClientFactory HttpClientFactory
@inject AppSettings AppSettings

<PageTitle>Choose a new password — SaasTemplate</PageTitle>

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&display=swap" rel="stylesheet" />
</HeadContent>

<a href="#reset-main" class="skip-link">Skip to main content</a>

<div class="login-page">

    <header class="login-header" role="banner">
        <a href="@AppSettings.FrontendUrl" aria-label="SaasTemplate — return to homepage" class="login-brand">
            <svg aria-hidden="true" width="24" height="32" viewBox="0 0 120 160" fill="none" class="login-brand-icon"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            SaasTemplate
        </a>
    </header>

    <main id="reset-main" class="login-main" tabindex="-1">
        <div class="login-card">

            @* Live regions — always in DOM so assistive tech announces changes *@
            <div role="alert" aria-atomic="true"
                 class="@(_error.Length > 0 ? "login-alert login-alert-error" : "sr-only")">@_error</div>
            <div role="status" aria-live="polite" aria-atomic="true"
                 class="@(_success ? "login-alert login-alert-success" : "sr-only")">
                @(_success ? "Your password has been reset." : "")
            </div>

            <h1 id="reset-heading" class="login-heading" tabindex="-1">Choose a new password</h1>

            @if (_success)
            {
                <p class="login-hint" style="text-align:left;margin-top:0;">
                    Your password has been reset. You can now sign in with your new password.
                </p>
                <p class="login-hint">
                    <a href="/login">Continue to sign in</a>
                </p>
            }
            else if (_linkInvalid)
            {
                <p class="login-hint" style="text-align:left;margin-top:0;">
                    This reset link is invalid or has expired. Please request a new one.
                </p>
                <p class="login-hint">
                    <a href="/auth/forgot-password">Request a new reset link</a>
                </p>
            }
            else if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            {
                <p class="login-hint" style="text-align:left;margin-top:0;">
                    This reset link is missing required information. Please request a new one.
                </p>
                <p class="login-hint">
                    <a href="/auth/forgot-password">Request a new reset link</a>
                </p>
            }
            else
            {
                <div class="login-form-group">
                    <label for="new-password" class="login-label">New password</label>
                    <input id="new-password" type="password"
                           @bind="_newPassword" @bind:event="oninput"
                           autocomplete="new-password"
                           required aria-required="true"
                           class="login-input"
                           aria-describedby="password-hint" />
                </div>

                <p id="password-hint" class="login-hint" style="text-align:left;margin-top:-0.25rem;margin-bottom:1rem;">
                    At least 12 characters and one symbol (e.g. !, ?, #).
                </p>

                <div class="login-form-group">
                    <label for="confirm-password" class="login-label">Confirm new password</label>
                    <input id="confirm-password" type="password"
                           @bind="_confirmPassword" @bind:event="oninput"
                           autocomplete="new-password"
                           required aria-required="true"
                           @onkeydown="OnConfirmKeyDown"
                           class="login-input" />
                </div>

                <button class="login-btn-primary" @onclick="Submit" disabled="@_loading">
                    @(_loading ? "Resetting…" : "Reset password")
                </button>

                <p class="login-hint">
                    <a href="/login">Back to sign in</a>
                </p>
            }

        </div>
    </main>
</div>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _newPassword = "";
    private string _confirmPassword = "";
    private string _error = "";
    private bool _loading;
    private bool _success;
    private bool _linkInvalid;

    private async Task OnConfirmKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    private async Task Submit()
    {
        if (_loading) return;
        _error = "";

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _error = "Please enter a new password.";
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            _error = "The passwords don't match. Please re-enter them.";
            return;
        }

        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("internal");
            var response = await client.PostAsJsonAsync("/api/auth/reset-password",
                new { email = Email, token = Token, newPassword = _newPassword });

            if (response.IsSuccessStatusCode)
            {
                _success = true;
                return;
            }

            // 400 ValidationProblem (password policy) → surface the policy messages.
            // Any other 400 → the token/user was bad; treat the link as invalid.
            var policyMessages = await TryReadPasswordPolicyErrorsAsync(response);
            if (policyMessages.Count > 0)
            {
                _error = string.Join(" ", policyMessages);
            }
            else
            {
                _linkInvalid = true;
            }
        }
        catch
        {
            _error = "Unable to reach the server. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    // ValidationProblem responses look like { "errors": { "PasswordTooShort": ["..."], ... } }.
    // Pull the human-readable descriptions out of the errors dictionary values.
    private static async Task<List<string>> TryReadPasswordPolicyErrorsAsync(HttpResponseMessage response)
    {
        var messages = new List<string>();
        try
        {
            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
            if (doc.RootElement.TryGetProperty("errors", out var errors) &&
                errors.ValueKind == JsonValueKind.Object)
            {
                foreach (var prop in errors.EnumerateObject())
                {
                    if (prop.Value.ValueKind == JsonValueKind.Array)
                    {
                        foreach (var item in prop.Value.EnumerateArray())
                        {
                            var msg = item.GetString();
                            if (!string.IsNullOrWhiteSpace(msg)) messages.Add(msg);
                        }
                    }
                }
            }
        }
        catch
        {
            // Not a ValidationProblem body — caller falls back to the generic invalid-link path.
        }
        return messages;
    }
}
