@page "/pricing"
@layout EmptyLayout
@using System.Net.Http.Json
@using Microsoft.JSInterop
@using Microsoft.Extensions.Logging
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject ILogger<Pricing> Logger
@inject AppSettings AppSettings

<PageTitle>Pricing — SaasTemplate</PageTitle>

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&display=swap" rel="stylesheet" />
</HeadContent>

<a href="#pricing-main" class="skip-link">Skip to main content</a>

<div class="pricing-page" aria-hidden="@(_showEmailForm ? "true" : null)" id="pricing-page-content">

    <header class="login-header" role="banner">
        <a href="@AppSettings.FrontendUrl" aria-label="SaasTemplate — return to homepage" class="login-brand">
            <svg aria-hidden="true" width="24" height="32" viewBox="0 0 120 160" fill="none" class="login-brand-icon"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            SaasTemplate
        </a>
    </header>

    <main id="pricing-main" class="pricing-main" tabindex="-1">

        <h1 class="pricing-heading">Choose your plan</h1>
        <p class="pricing-subheading">Start scanning your Shopify store for WCAG 2.1 AA violations and get code fixes you can actually apply.</p>

        @* Live regions — always in DOM *@
        <div id="pricing-error" role="alert" aria-atomic="true"
             class="@(_error.Length > 0 ? "login-alert login-alert-error" : "sr-only")">@_error</div>
        <div id="pricing-status" role="status" aria-live="polite" aria-atomic="true"
             class="@(_statusMessage.Length > 0 ? "login-alert login-alert-success" : "sr-only")">@_statusMessage</div>

        @* Billing interval toggle — ARIA radio group with roving tabindex *@
        <div class="pricing-toggle" role="radiogroup" aria-label="Billing interval">
            <button id="toggle-monthly" type="button" role="radio"
                    aria-checked="@(!_isAnnual ? "true" : "false")"
                    tabindex="@(!_isAnnual ? "0" : "-1")"
                    class="pricing-toggle-btn @(!_isAnnual ? "pricing-toggle-active" : "")"
                    @onclick="() => SetInterval(false)"
                    @onkeydown="e => OnToggleKeyDown(e, true)">Monthly</button>
            <button id="toggle-annual" type="button" role="radio"
                    aria-checked="@(_isAnnual ? "true" : "false")"
                    tabindex="@(_isAnnual ? "0" : "-1")"
                    class="pricing-toggle-btn @(_isAnnual ? "pricing-toggle-active" : "")"
                    @onclick="() => SetInterval(true)"
                    @onkeydown="e => OnToggleKeyDown(e, false)">Annual <span class="pricing-save-badge">Save 10%</span></button>
        </div>
        <p id="billing-interval-status" role="status" aria-live="polite" class="sr-only">
            @(_isAnnual ? "Annual billing selected — 10% discount applied" : "Monthly billing selected")
        </p>

        <div class="pricing-included" style="display:flex;flex-wrap:wrap;justify-content:center;gap:1rem 2rem;margin-bottom:2rem;color:rgba(255,255,255,0.8);font-size:0.875rem;">
            <span>&#10003; Free scan included</span>
            <span>&#10003; Cancel anytime</span>
            <span>&#10003; Code fixes you review first</span>
            <span>&#10003; Compliance PDF reports</span>
        </div>

        @* Plan cards *@
        <div class="pricing-cards">
            @foreach (var plan in _plans)
            {
                <article aria-labelledby="plan-@plan.Tier-heading"
                         aria-describedby="@(plan.Highlighted || plan.ComingSoon ? $"plan-{plan.Tier}-badge" : null)"
                         class="pricing-card @(plan.Highlighted ? "pricing-card-highlighted" : "") @(plan.ComingSoon ? "pricing-card-coming-soon" : "")">
                    @if (plan.Highlighted)
                    {
                        <div id="plan-@plan.Tier-badge" class="pricing-badge pricing-badge-popular">Most Popular</div>
                    }
                    @if (plan.ComingSoon)
                    {
                        <div id="plan-@plan.Tier-badge" class="pricing-badge pricing-badge-soon">Coming Soon</div>
                    }
                    <div>
                        <h2 id="plan-@plan.Tier-heading" class="pricing-plan-name">@plan.Label</h2>
                        <div class="pricing-plan-price">
                            @(_isAnnual ? plan.AnnualPrice : $"${plan.MonthlyPrice}")
                            <span class="pricing-plan-suffix">@(_isAnnual ? "/yr" : "/mo")</span>
                        </div>
                        <p class="pricing-billing-note">
                            @(_isAnnual ? "Billed annually \u2014 save 10%" : "Cancel anytime")
                        </p>
                    </div>
                    <ul class="pricing-feature-list">
                        @foreach (var feature in plan.Features)
                        {
                            <li><span aria-hidden="true" class="pricing-check">&#10003;</span> @feature</li>
                        }
                    </ul>
                    @if (plan.ComingSoon)
                    {
                        <button id="cta-@plan.Tier" type="button"
                                class="pricing-btn pricing-btn-secondary pricing-btn-disabled"
                                aria-disabled="true"
                                aria-describedby="plan-@plan.Tier-cta-note"
                                @onclick:preventDefault="true">Coming Soon</button>
                        <p id="plan-@plan.Tier-cta-note" class="sr-only">This plan is not yet available for purchase. Check back soon.</p>
                    }
                    else
                    {
                        <button id="cta-@plan.Tier" type="button"
                                class="pricing-btn @(plan.Highlighted ? "pricing-btn-primary" : "pricing-btn-secondary")"
                                disabled="@(_subscribing == plan.Tier)"
                                @onclick="() => OpenEmailDialog(plan.Tier)"
                                aria-label="@($"Get started with {plan.Label} — {(_isAnnual ? plan.AnnualPrice + " per year" : "$" + plan.MonthlyPrice + " per month")}")">
                            @(_subscribing == plan.Tier ? "Redirecting\u2026" : "Get Started")
                        </button>
                    }
                </article>
            }
        </div>

        <p style="text-align:center;color:rgba(255,255,255,0.7);font-size:0.875rem;margin:2rem 0 3rem;max-width:36rem;margin-left:auto;margin-right:auto;">
            Join Shopify store owners who fixed their accessibility issues at the source — not with an overlay widget.
        </p>

        @* Feature comparison table *@
        <div class="pricing-table-wrap">
            <table class="pricing-table">
                <caption class="pricing-table-caption">Feature comparison</caption>
                <thead>
                    <tr>
                        <th scope="col" class="pricing-th pricing-th-feature">Feature</th>
                        <th scope="col" class="pricing-th pricing-th-plan">Starter<br><span class="pricing-th-price">@(_isAnnual ? "$529/yr" : "$49/mo")</span></th>
                        <th scope="col" class="pricing-th pricing-th-plan">Professional<br><span class="pricing-th-price">@(_isAnnual ? "$1,069/yr" : "$99/mo")</span></th>
                        <th scope="col" class="pricing-th pricing-th-plan">Business<br><span class="pricing-th-price">@(_isAnnual ? "$1,609/yr" : "$149/mo")</span></th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="pricing-tr-alt">
                        <th scope="row" class="pricing-td-feature">Scans per month</th>
                        <td class="pricing-td">10</td>
                        <td class="pricing-td">30</td>
                        <td class="pricing-td">Unlimited</td>
                    </tr>
                    <tr>
                        <th scope="row" class="pricing-td-feature">Pages per scan</th>
                        <td class="pricing-td">5</td>
                        <td class="pricing-td">10</td>
                        <td class="pricing-td">25</td>
                    </tr>
                    <tr class="pricing-tr-alt">
                        <th scope="row" class="pricing-td-feature">Code fix generation</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr>
                        <th scope="row" class="pricing-td-feature">Compliance score (0-100)</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr class="pricing-tr-alt">
                        <th scope="row" class="pricing-td-feature">CSV data export</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr>
                        <th scope="row" class="pricing-td-feature">Compliance PDF report</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr class="pricing-tr-alt">
                        <th scope="row" class="pricing-td-feature">Weekly automated monitoring</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr>
                        <th scope="row" class="pricing-td-feature">AI deep analysis (2nd-pass)</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td">Weekly auto-scan</td>
                        <td class="pricing-td">Weekly auto-scan</td>
                    </tr>
                    <tr class="pricing-tr-alt">
                        <th scope="row" class="pricing-td-feature">VPAT generation</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                    <tr>
                        <th scope="row" class="pricing-td-feature">Custom rules engine</th>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-dash">&#x2014;</span><span class="sr-only">Not included</span></td>
                        <td class="pricing-td"><span aria-hidden="true" class="pricing-check-table">&#10003;</span><span class="sr-only">Included</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <p class="pricing-back-link">
            <a href="@AppSettings.FrontendUrl"><span aria-hidden="true">&#x2190;</span> Back to homepage</a>
        </p>

        <p class="pricing-login-link">
            Already have an account? <a href="/login">Sign in</a>
        </p>
    </main>
</div>

@* Email dialog — outside pricing-page-content so aria-hidden doesn't hide it *@
@if (_showEmailForm)
{
    <div class="pricing-email-overlay" @onclick="CloseEmailFormAsync"
         @onkeydown="OnDialogKeyDown">
        <div id="email-dialog" class="pricing-email-card" role="dialog" aria-modal="true"
             aria-labelledby="email-dialog-heading"
             @onclick:stopPropagation="true">
            <h2 id="email-dialog-heading" class="pricing-email-heading">Enter your email to continue</h2>
            <p class="pricing-email-subtitle">
                We'll create your account and redirect you to secure checkout for
                <strong>@_selectedPlanLabel</strong>.
            </p>

            <div class="login-form-group">
                <label for="checkout-email" class="login-label">Email address</label>
                <input id="checkout-email" type="email"
                       @bind="_email" @bind:event="oninput"
                       autocomplete="email"
                       required aria-required="true"
                       @onkeydown="OnEmailKeyDown"
                       class="login-input"
                       placeholder="you@example.com"
                       aria-describedby="@(_emailError.Length > 0 ? "checkout-email-error" : null)"
                       aria-invalid="@(_emailError.Length > 0 ? "true" : "false")" />
            </div>

            <div id="checkout-email-error" role="alert" aria-atomic="true"
                 class="@(_emailError.Length > 0 ? "login-alert login-alert-error" : "sr-only")">@_emailError</div>

            <button type="button" class="login-btn-primary" @onclick="SubmitCheckout" disabled="@_loading">
                @(_loading ? "Redirecting\u2026" : "Continue to checkout")
            </button>

            <button type="button" class="pricing-email-close" @onclick="CloseEmailFormAsync"
                    aria-label="Close dialog">
                <span aria-hidden="true">&#x2715;</span>
            </button>
        </div>
    </div>
}

@code {
    private string _email = "";
    private string _error = "";
    private string _statusMessage = "";
    private string _emailError = "";
    private bool _loading;
    private bool _isAnnual;
    private bool _showEmailForm;
    private string? _subscribing;
    private string _selectedTier = "";
    private string _selectedPlanLabel = "";

    private static readonly PlanInfo[] _plans =
    [
        new("starter",      "Starter",      49,  "$529",   false, false, ["10 scans/month, 5 pages each", "Code fix generation (Liquid patches)", "Compliance score (0-100)", "Compliance PDF report"]),
        new("professional", "Professional", 99,  "$1,069", true,  false, ["30 scans/month, 10 pages each", "Everything in Starter", "Weekly automated monitoring", "AI deep analysis on weekly scan"]),
        new("business",     "Business",     149, "$1,609", false, false, ["Unlimited scans, 25 pages each", "Everything in Professional", "VPAT generation", "Custom rules engine"]),
    ];

    private void SetInterval(bool annual) => _isAnnual = annual;

    private async Task OnToggleKeyDown(KeyboardEventArgs e, bool isCurrentlyMonthly)
    {
        // ARIA radio group arrow key pattern: Right/Down = next, Left/Up = previous
        if (isCurrentlyMonthly && e.Key is "ArrowRight" or "ArrowDown")
        {
            _isAnnual = true;
            await JS.InvokeVoidAsync("loginFocusTab", "toggle-annual");
        }
        else if (!isCurrentlyMonthly && e.Key is "ArrowLeft" or "ArrowUp")
        {
            _isAnnual = false;
            await JS.InvokeVoidAsync("loginFocusTab", "toggle-monthly");
        }
    }

    private async Task OpenEmailDialog(string tier)
    {
        _error = "";
        _selectedTier = tier;
        _selectedPlanLabel = _plans.First(p => p.Tier == tier).Label;
        _showEmailForm = true;
        StateHasChanged();
        // After render: trap focus in the dialog
        await Task.Yield();
        await JS.InvokeVoidAsync("trapFocus", "email-dialog");
    }

    private async Task CloseEmailFormAsync()
    {
        var returnTarget = $"cta-{_selectedTier}";
        _showEmailForm = false;
        _emailError = "";
        _subscribing = null;
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("releaseFocus", "email-dialog", returnTarget);
    }

    private async Task OnDialogKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseEmailFormAsync();
    }

    private async Task OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitCheckout();
    }

    private async Task SubmitCheckout()
    {
        _emailError = "";
        _error = "";

        if (string.IsNullOrWhiteSpace(_email))
        {
            _emailError = "Email is required.";
            return;
        }

        _loading = true;
        _subscribing = _selectedTier;
        try
        {
            var client = HttpClientFactory.CreateClient("internal");
            var response = await client.PostAsJsonAsync("/api/billing/public-checkout", new
            {
                tier = _selectedTier,
                email = _email,
                interval = _isAnnual ? "annual" : "monthly"
            });

            if (response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadFromJsonAsync<CheckoutResponse>();

                if (body?.Action == "login")
                {
                    await CloseEmailFormAsync();
                    _statusMessage = body.Message ?? "You already have an active subscription. Sign in to manage your plan.";
                    return;
                }

                if (body?.Url is not null)
                {
                    // Defense-in-depth: only redirect to Stripe checkout URLs
                    if (Uri.TryCreate(body.Url, UriKind.Absolute, out var checkoutUri)
                        && checkoutUri.Host.EndsWith(".stripe.com", StringComparison.OrdinalIgnoreCase))
                    {
                        Nav.NavigateTo(body.Url, forceLoad: true);
                        return;
                    }

                    Logger.LogWarning("Public checkout returned unexpected redirect URL: {Host}", checkoutUri?.Host ?? "invalid");
                    _emailError = "Unexpected checkout URL. Please try again.";
                    return;
                }

                _emailError = "Unexpected response from billing service.";
            }
            else
            {
                var errorBody = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _emailError = errorBody?.Error ?? "Could not start checkout. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Public checkout request failed for tier {Tier}", _selectedTier);
            _emailError = "Unable to reach the server. Please try again.";
        }
        finally
        {
            _loading = false;
            _subscribing = null;
        }
    }

    private sealed record PlanInfo(string Tier, string Label, int MonthlyPrice, string AnnualPrice, bool Highlighted, bool ComingSoon, string[] Features);
    private sealed record CheckoutResponse(string? Url = null, string? Action = null, string? Message = null);
    private sealed record ErrorResponse(string? Error);
}
