@page "/login"
@layout EmptyLayout
@using System.Net.Http.Json
@using SaasTemplate.Api.Auth
@inject DashboardSession Session
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@inject AppSettings AppSettings

<PageTitle>Sign in — SaasTemplate</PageTitle>

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&display=swap" rel="stylesheet" />
</HeadContent>

<a href="#login-main" class="skip-link">Skip to main content</a>

<div class="login-page">

    <header class="login-header" role="banner">
        <a href="@AppSettings.FrontendUrl" aria-label="SaasTemplate — return to homepage" class="login-brand">
            <svg aria-hidden="true" width="24" height="32" viewBox="0 0 120 160" fill="none" class="login-brand-icon"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            SaasTemplate
        </a>
    </header>

    <main id="login-main" class="login-main" tabindex="-1">
        <div class="login-card">

            @* Live regions — always in DOM so screen readers catch content changes *@
            <div id="email-error" role="alert" aria-atomic="true"
                 class="@(_error.Length > 0 ? "login-alert login-alert-error" : "sr-only")">@_error</div>
            <div role="status" aria-live="polite" aria-atomic="true"
                 class="@(_success.Length > 0 ? "login-alert login-alert-success" : "sr-only")">@_success</div>

            <h1 class="login-heading">Access your dashboard</h1>

            <div class="login-form-group">
                <label for="email" class="login-label">Email address</label>
                <input id="email" type="email"
                       @bind="_email" @bind:event="oninput"
                       autocomplete="email"
                       required aria-required="true"
                       @onkeydown="OnEmailKeyDown"
                       class="login-input"
                       placeholder="you@example.com"
                       aria-describedby="@(_error.Length > 0 ? "email-hint email-error" : "email-hint")"
                       aria-invalid="@(_error.Length > 0 ? "true" : null)" />
            </div>

            <button class="login-btn-primary" @onclick="SendMagicLink" disabled="@_loading">
                @(_loading ? "Sending\u2026" : "Email me a sign-in link")
            </button>

            <p id="email-hint" class="login-hint">
                We'll email you a secure one-time link. Works for new and existing accounts &mdash; no password needed.
            </p>

            <div class="login-divider" role="separator" aria-label="or">
                <span aria-hidden="true">or</span>
            </div>

            <a href="/api/auth/google" class="login-btn-google">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 48 48"><path fill="#4285F4" d="M44.5 20H24v8.5h11.7C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 11.8 2 2 11.8 2 24s9.8 22 22 22c11 0 21-8 21-22 0-1.3-.2-2.7-.5-4z"/><path fill="#34A853" d="M6.3 14.7l7 5.1C15 15.6 19.1 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 16 2 9.2 6.8 6.3 14.7z"/><path fill="#FBBC05" d="M24 46c5.4 0 10.3-1.8 14.1-4.9l-6.5-5.5C29.5 37.5 26.9 38 24 38c-6 0-11.1-3.7-13.3-9l-7 5.4C6.8 41.2 14.7 46 24 46z"/><path fill="#EA4335" d="M44.5 20H24v8.5h11.7c-.9 3-3.2 5.5-6.2 7l6.5 5.5c3.8-3.5 6-8.7 6-14.5 0-1.3-.2-2.7-.5-4V20z"/></svg>
                Continue with Google
            </a>

        </div>

        <p class="login-back-link">
            <a href="@AppSettings.FrontendUrl"><span aria-hidden="true">&#x2190;</span> Back to homepage</a>
        </p>
    </main>
</div>

@code {
    private string _email = "";
    private string _error = "";
    private string _success = "";
    private bool _loading;

    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Nav.NavigateTo("/");
            return;
        }

        // Handle OAuth error redirects
        var uri = new Uri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("error", out var errorParam))
        {
            _error = errorParam.ToString() switch
            {
                "oauth-failed" => "Google sign-in failed. Please try again or use email sign-in.",
                "no-email" => "Could not retrieve your email from Google. Please use email sign-in.",
                "create-failed" => "Account creation failed. Please try again.",
                _ => "Something went wrong. Please try again."
            };
        }
    }

    private async Task OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMagicLink();
    }

    private async Task SendMagicLink()
    {
        _error = "";
        _success = "";

        if (string.IsNullOrWhiteSpace(_email)) { _error = "Email is required."; return; }

        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("internal");
            var response = await client.PostAsJsonAsync("/api/auth/magic-link",
                new { email = _email });

            if (response.IsSuccessStatusCode)
                _success = "Check your email \u2014 we sent you a sign-in link. It expires in 15 minutes.";
            else
                _error = "Something went wrong. Please try again.";
        }
        catch
        {
            _error = "Unable to reach the server. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
