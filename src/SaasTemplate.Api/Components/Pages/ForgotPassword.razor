@page "/auth/forgot-password"
@layout EmptyLayout
@using System.Net.Http.Json
@using SaasTemplate.Api.Auth
@inject IHttpClientFactory HttpClientFactory
@inject AppSettings AppSettings

<PageTitle>Reset your password — SaasTemplate</PageTitle>

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&display=swap" rel="stylesheet" />
</HeadContent>

<a href="#forgot-main" class="skip-link">Skip to main content</a>

<div class="login-page">

    <header class="login-header" role="banner">
        <a href="@AppSettings.FrontendUrl" aria-label="SaasTemplate — return to homepage" class="login-brand">
            <svg aria-hidden="true" width="24" height="32" viewBox="0 0 120 160" fill="none" class="login-brand-icon"><path d="M60 8 L108 30 L108 90 C108 118 88 140 60 152 C32 140 12 118 12 90 L12 30 Z" fill="none" stroke="#00A8E8" stroke-width="4"/><polyline points="47,78 56,88 74,68" fill="none" stroke="#fff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            SaasTemplate
        </a>
    </header>

    <main id="forgot-main" class="login-main" tabindex="-1">
        <div class="login-card">

            @* Live region — always in DOM so screen readers catch the confirmation *@
            <div role="status" aria-live="polite" aria-atomic="true"
                 class="@(_submitted ? "login-alert login-alert-success" : "sr-only")">
                @(_submitted ? GenericConfirmation : "")
            </div>

            <h1 id="forgot-heading" class="login-heading" tabindex="-1">Reset your password</h1>

            @if (_submitted)
            {
                <p class="login-hint" style="text-align:left;margin-top:0;">
                    @GenericConfirmation
                </p>
            }
            else
            {
                <p class="login-hint" style="text-align:left;margin-top:0;margin-bottom:1rem;">
                    Enter the email address for your account and we'll send you a link to choose a new password.
                </p>

                <div class="login-form-group">
                    <label for="email" class="login-label">Email address</label>
                    <input id="email" type="email"
                           @bind="_email" @bind:event="oninput"
                           autocomplete="email"
                           required aria-required="true"
                           @onkeydown="OnEmailKeyDown"
                           class="login-input"
                           placeholder="you@example.com" />
                </div>

                <button class="login-btn-primary" @onclick="Submit" disabled="@_loading">
                    @(_loading ? "Sending…" : "Send reset link")
                </button>
            }

            <p class="login-hint">
                <a href="/login">Back to sign in</a>
            </p>

        </div>
    </main>
</div>

@code {
    private const string GenericConfirmation =
        "If an account exists for that email, we've sent a reset link.";

    private string _email = "";
    private bool _loading;
    private bool _submitted;

    private async Task OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }

    private async Task Submit()
    {
        if (_loading || _submitted) return;
        _loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("internal");
            // Fire the request, but always show the same confirmation regardless of
            // the result (or a transport error) to preserve anti-enumeration.
            await client.PostAsJsonAsync("/api/auth/forgot-password", new { email = _email });
        }
        catch
        {
            // Swallow — never reveal whether the request succeeded.
        }
        finally
        {
            _loading = false;
            _submitted = true;
        }
    }
}
