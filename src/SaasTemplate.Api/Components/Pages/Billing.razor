@code {
    private SubscriptionInfo? _subscription;
    private string? _subscribing;
    private string _error = "";
    private bool _loading = true;
    private bool _portalLoading;
    private bool _checkoutSuccess;
    private bool _checkoutCancelled;
    private bool _polling;
    private bool _cancelLoading;
    private ElementReference _cancelDialog;

    // S13-002: post-checkout onboarding form state
    private string _onboardUrl = "";
    private bool _onboardSubmitting;
    private string _onboardError = "";

    // S16-002: ToS acceptance
    private bool _tosAccepted;
    private int _utcOffset;

    // S31-003: change plan dialog state
    private string? _changingPlan;
    private string _changePlanTargetTier = "";
    private string _changePlanTargetLabel = "";
    private int _changePlanTargetPrice;
    private ElementReference _changePlanDialog;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _utcOffset = await JS.InvokeAsync<int>("getTimezoneOffset");
            StateHasChanged();
        }
    }

    private static readonly PlanInfo[] _plans =
    [
        new("starter",      "Starter",      49,  false, false, ["10 scans/month, 5 pages each", "Code fix generation (Liquid patches)", "Compliance score (0-100)", "Compliance PDF report"]),
        new("professional", "Professional", 99,  true,  false, ["30 scans/month, 10 pages each", "Everything in Starter", "Weekly automated monitoring", "AI deep analysis on weekly scan"]),
        new("business",     "Business",     149, false, false, ["Unlimited scans, 25 pages each", "Everything in Professional", "VPAT generation", "Custom rules engine"]),
    ];

    private static string CardStyle(PlanInfo plan)
    {
        var s = "display:flex;flex-direction:column;gap:1rem;position:relative;";
        if (plan.Highlighted) s += "border-color:var(--primary);box-shadow:0 0 0 2px var(--primary);";
        if (plan.ComingSoon) s += "opacity:0.8;";
        return s;
    }

    private static string? BadgeId(PlanInfo plan) =>
        (plan.Highlighted || plan.ComingSoon) ? $"plan-{plan.Tier}-badge" : null;

    /// <summary>
    /// Returns PlanInfo records for all tiers except the current subscription tier.
    /// Used to show both upgrade and downgrade options.
    /// </summary>
    private static PlanInfo[] GetChangeTiers(string currentTier) =>
        _plans.Where(p => p.Tier != currentTier && !p.ComingSoon).ToArray();

    /// <summary>
    /// Returns the monthly price for a given tier.
    /// </summary>
    private static int GetCurrentPlanPrice(string tier) =>
        _plans.FirstOrDefault(p => p.Tier == tier)?.Price ?? 0;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        // Parse ?checkout=success|cancelled from the return URL
        var uri = new Uri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("checkout", out var checkoutParam))
        {
            _checkoutSuccess = checkoutParam == "success";
            _checkoutCancelled = checkoutParam == "cancelled";
        }

        var client = CreateAuthorizedClient();
        var response = await client.GetAsync("/api/billing/subscription");

        if (response.IsSuccessStatusCode)
        {
            _subscription = await response.Content.ReadFromJsonAsync<SubscriptionInfo>();
        }
        else if (_checkoutSuccess)
        {
            // Webhook may not have processed yet — poll for up to 30 seconds
            _polling = true;
            _loading = false;
            StateHasChanged();

            _subscription = await PollForSubscription(client);
            _polling = false;
        }
        // 404 = no subscription yet — that's fine, show the pricing cards

        _loading = false;
    }

    /// <summary>
    /// Polls the subscription endpoint every 2 seconds for up to 30 seconds,
    /// giving the Stripe webhook time to process after checkout.
    /// </summary>
    private async Task<SubscriptionInfo?> PollForSubscription(HttpClient client)
    {
        const int maxAttempts = 15; // 15 * 2s = 30s
        for (int i = 0; i < maxAttempts; i++)
        {
            await Task.Delay(2000);
            var response = await client.GetAsync("/api/billing/subscription");
            if (response.IsSuccessStatusCode)
            {
                return await response.Content.ReadFromJsonAsync<SubscriptionInfo>();
            }
        }
        return null;
    }

    private async Task Subscribe(string tier)
    {
        _error = "";
        _subscribing = tier;
        try
        {
            var client = CreateAuthorizedClient();

            // Record ToS acceptance server-side before initiating checkout
            var tosResponse = await client.PostAsync("/api/billing/accept-tos", null);
            if (!tosResponse.IsSuccessStatusCode)
            {
                _error = "Could not record Terms of Service acceptance. Please try again.";
                return;
            }

            var response = await client.PostAsJsonAsync("/api/billing/checkout", new { tier });

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not start checkout. Please try again.";
                return;
            }

            var body = await response.Content.ReadFromJsonAsync<CheckoutResult>();
            if (body?.Url is null)
            {
                _error = "Unexpected response from billing service.";
                return;
            }

            Nav.NavigateTo(body.Url, forceLoad: true);
        }
        catch
        {
            _error = "Unable to reach the billing service. Please try again.";
        }
        finally
        {
            _subscribing = null;
        }
    }

    // S31-003: change plan dialog methods
    private async Task OpenChangePlanDialog(string tier, string label, int price)
    {
        _changePlanTargetTier = tier;
        _changePlanTargetLabel = label;
        _changePlanTargetPrice = price;
        StateHasChanged();
        await JS.InvokeVoidAsync("showDialog", _changePlanDialog);
    }

    private async Task CloseChangePlanDialog()
    {
        await JS.InvokeVoidAsync("closeDialog", _changePlanDialog);
    }

    private async Task ConfirmChangePlan()
    {
        _error = "";
        _changingPlan = _changePlanTargetTier;
        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.PostAsJsonAsync(
                "/api/billing/change-plan", new { tier = _changePlanTargetTier });

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _error = body?.Error ?? "Could not change plan. Please try again.";
                return;
            }

            // Refresh subscription data to reflect the new tier
            var subResponse = await client.GetAsync("/api/billing/subscription");
            if (subResponse.IsSuccessStatusCode)
                _subscription = await subResponse.Content.ReadFromJsonAsync<SubscriptionInfo>();

            await CloseChangePlanDialog();
        }
        catch
        {
            _error = "Unable to reach the billing service. Please try again.";
        }
        finally
        {
            _changingPlan = null;
        }
    }

    // S13-002: submit the first scan from the post-checkout onboarding form
    private async Task SubmitOnboardScan()
    {
        _onboardError = "";
        var url = _onboardUrl.Trim();

        if (string.IsNullOrEmpty(url))
        {
            _onboardError = "Please enter your store URL.";
            return;
        }

        if (!Uri.TryCreate(url, UriKind.Absolute, out var parsed) ||
            (parsed.Scheme != "http" && parsed.Scheme != "https"))
        {
            _onboardError = "URL must start with http:// or https://";
            return;
        }

        _onboardSubmitting = true;
        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.PostAsJsonAsync("/api/scans", new { url, email = "" });

            if (response.StatusCode == HttpStatusCode.Accepted)
            {
                Nav.NavigateTo("/scans");
            }
            else if (response.StatusCode == HttpStatusCode.PaymentRequired)
            {
                _onboardError = "Subscription is activating — please try again in a moment.";
            }
            else
            {
                _onboardError = "Could not start the scan. Please try again.";
            }
        }
        catch
        {
            _onboardError = "Unable to reach the server. Please try again.";
        }
        finally
        {
            _onboardSubmitting = false;
        }
    }

    private async Task OpenPortal()
    {
        _portalLoading = true;
        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.PostAsync("/api/billing/portal", null);

            if (!response.IsSuccessStatusCode)
            {
                _error = "Could not open billing portal. Please try again.";
                return;
            }

            var body = await response.Content.ReadFromJsonAsync<PortalResult>();
            if (body?.Url is not null)
                Nav.NavigateTo(body.Url, forceLoad: true);
        }
        catch
        {
            _error = "Unable to reach the billing service. Please try again.";
        }
        finally
        {
            _portalLoading = false;
        }
    }

    private async Task OpenCancelDialog()
    {
        await JS.InvokeVoidAsync("showDialog", _cancelDialog);
    }

    private async Task CloseCancelDialog()
    {
        await JS.InvokeVoidAsync("closeDialog", _cancelDialog);
    }

    private async Task ConfirmCancel()
    {
        _cancelLoading = true;
        try
        {
            // Redirect to Stripe portal for cancellation
            await OpenPortal();
        }
        finally
        {
            _cancelLoading = false;
            await CloseCancelDialog();
        }
    }

    private HttpClient CreateAuthorizedClient()
    {
        var client = HttpClientFactory.CreateClient("internal");
        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", Session.Token);
        return client;
    }

    private static string TierLabel(string tier, bool labelOnly = false) => tier switch
    {
        "starter"      => labelOnly ? "Starter" : "Starter — $49/mo",
        "professional" => labelOnly ? "Professional" : "Professional — $99/mo",
        "business"     => labelOnly ? "Business" : "Business — $149/mo",
        _              => tier
    };

    /// <summary>
    /// D-014 fix: derives current plan features from _plans array.
    /// Expands "Everything in [tier]" references recursively.
    /// </summary>
    private string[] _currentPlanFeatures => DeriveFeatures(_subscription?.Tier);

    private static string[] DeriveFeatures(string? tier)
    {
        if (tier is null) return [];

        var plan = _plans.FirstOrDefault(p => p.Tier == tier);
        if (plan is null) return [];

        var features = new List<string>();
        foreach (var feature in plan.Features)
        {
            if (feature.StartsWith("Everything in ", StringComparison.OrdinalIgnoreCase))
            {
                var referencedLabel = feature["Everything in ".Length..];
                var referencedPlan = _plans.FirstOrDefault(
                    p => p.Label.Equals(referencedLabel, StringComparison.OrdinalIgnoreCase));
                if (referencedPlan is not null)
                {
                    features.AddRange(DeriveFeatures(referencedPlan.Tier));
                }
            }
            else
            {
                features.Add(feature);
            }
        }

        return features.ToArray();
    }

    private sealed record SubscriptionInfo(string Tier, string Status, DateTime? CurrentPeriodEnd, int ScansUsed = 0, int ScansLimit = 0);
    private sealed record CheckoutResult(string Url);
    private sealed record PlanInfo(string Tier, string Label, int Price, bool Highlighted, bool ComingSoon, string[] Features);
    private sealed record PortalResult(string Url);
    private sealed record ErrorResponse(string? Error);
}
